// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  // {
  //   "context": "vim_mode == insert",
  //   "bindings": {
  //     "j j": "vim::NormalBefore",
  //     "j k": "vim::NormalBefore",
  //   },
  // },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "shift-u": "vim::Redo",
      "space e": "project_panel::ToggleFocus",
      "space t": "terminal_panel::Toggle",
      "space f": "file_finder::Toggle",
      "space b": "tab_switcher::Toggle",
      "space w": "workspace::Save",
      "space q": "pane::CloseActiveItem",
      "space r": ["action::Sequence", ["workspace::Save", "task::Spawn"]],
      "space g": ["task::Spawn", { "task_name": "lazygit" }],
    },
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "space": null, // Disable the default action vim::WrappingRight
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "space e": "workspace::CloseActiveDock",
      "escape": "project_panel::ToggleFocus",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      // "escape": "terminal_panel::Toggle",
      "alt-space": "terminal_panel::Toggle",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "shift shift": null,
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-1": ["pane::ActivateItem", 0],
      "cmd-2": ["pane::ActivateItem", 1],
      "cmd-3": ["pane::ActivateItem", 2],
      "cmd-4": ["pane::ActivateItem", 3],
      "cmd-5": ["pane::ActivateItem", 4],
      "cmd-6": ["pane::ActivateItem", 5],
      "cmd-7": ["pane::ActivateItem", 6],
      "cmd-8": ["pane::ActivateItem", 7],
      "cmd-9": ["pane::ActivateItem", 8],
      "ctrl-1": ["workspace::ActivatePane", 0],
      "ctrl-2": ["workspace::ActivatePane", 1],
      "ctrl-3": ["workspace::ActivatePane", 2],
      "ctrl-4": ["workspace::ActivatePane", 3],
      "ctrl-5": ["workspace::ActivatePane", 4],
      "ctrl-6": ["workspace::ActivatePane", 5],
      "ctrl-7": ["workspace::ActivatePane", 6],
      "ctrl-8": ["workspace::ActivatePane", 7],
      "ctrl-9": ["workspace::ActivatePane", 8],
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "l": "project_panel::Open",
    },
  },
]
