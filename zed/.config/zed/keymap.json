// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "j j": "vim::NormalBefore",
      "j k": "vim::NormalBefore",
    },
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "shift-u": "vim::Redo",
    },
  },
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "H": "vim::FirstNonWhitespace",
      "L": "vim::EndOfLine",
      "ctrl-j": [
        "action::Sequence",
        ["vim::ScrollDown", "editor::ScrollCursorCenter"],
      ],
      "ctrl-k": [
        "action::Sequence",
        ["vim::ScrollUp", "editor::ScrollCursorCenter"],
      ],
    },
  },
  {
    "context": "Editor",
    "bindings": {
      // "ctrl-w": "editor::SelectLargerSyntaxNode",
      // "alt-up": "editor::MoveToStartOfParagraph",
      // "alt-down": "editor::MoveToEndOfParagraph",
      // "cmd-shift-w": "editor::SelectSmallerSyntaxNode",
    },
  },
]
